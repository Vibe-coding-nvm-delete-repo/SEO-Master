#!/bin/sh

echo "Running pre-commit checks..."

# TypeScript type check
echo "  [1/3] TypeScript..."
npx tsc --noEmit || {
  echo "TypeScript check failed. Fix type errors before committing."
  exit 1
}

# ESLint (warnings OK, errors block)
echo "  [2/3] ESLint..."
npx eslint src/ --max-warnings=100 --rule 'no-empty: warn' --rule 'no-control-regex: warn' --rule 'no-useless-escape: warn' || {
  echo "ESLint check failed. Fix lint errors before committing."
  exit 1
}

# Tests
echo "  [3/3] Tests..."
NAPI_RS_FORCE_WASI=1 npx vitest run || {
  echo "Tests failed. Fix failing tests before committing."
  exit 1
}

echo "All checks passed!"
