rules_version = '2';
// Open access for this workspace app. Includes `projects/*`, `app_settings/*` (e.g. user_preferences,
// universal_blocked, project_folders), and generate/autogroup docs. Tighten before production if needed.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
