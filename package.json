{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit && eslint src/ && node scripts/check-chunk-writer.cjs",
    "collab:census": "node scripts/collab/census.mjs --write .deploy/collab/firestore-census.json",
    "collab:audit": "node scripts/collab/audit.mjs --write .deploy/collab/firestore-signoff.json",
    "collab:coverage": "node scripts/collab/coverage.mjs --write .deploy/collab/shared-action-coverage-signoff.json",
    "collab:convergence": "npx vitest run src/appSettingsCollab.integration.test.ts src/projectMetadataCollab.test.ts src/App.shared-projects.integration.test.tsx src/useProjectPersistence.v2.test.tsx && npm run test:firestore-rules && npm run test:e2e:collab",
    "collab:gate": "npm run collab:census && npm run collab:audit && npm run collab:coverage && npm run collab:convergence",
    "collab:release-gate": "npm run collab:gate && npx tsc --noEmit && npx vitest run && npx vite build",
    "release:check": "npm run collab:release-gate && node scripts/release.mjs check",
    "release:preview": "npm run collab:release-gate && node scripts/release.mjs preview",
    "release:live": "npm run collab:release-gate && node scripts/release.mjs live",
    "backup:firestore:status": "node scripts/firestore-backup.mjs status",
    "backup:firestore:ensure": "node scripts/firestore-backup.mjs ensure",
    "migrate:shared:v2": "tsx scripts/migrate-shared-projects-v2.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run src/App.shared-projects.integration.test.tsx",
    "test:firestore-rules": "node scripts/collab/runFirestoreRules.mjs",
    "test:e2e": "playwright test",
    "test:e2e:collab": "playwright test e2e/content-shared-state.spec.ts e2e/collaboration-two-session.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "postinstall": "node scripts/patch-wasm.cjs",
    "setup": "npm install --ignore-scripts && npm install --ignore-scripts esbuild-wasm @rollup/wasm-node @tailwindcss/oxide-wasm32-wasi --force && node scripts/patch-wasm.cjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "all-the-cities": "^3.1.0",
    "clsx": "^2.1.1",
    "country-state-city": "^3.2.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "firebase-tools": "^15.11.0",
    "isomorphic-git": "^1.37.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "pluralize": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "eslint-plugin-react-hooks": {
      "eslint": "$eslint"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "@types/pluralize": "^0.0.33",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.2.0",
    "vitest": "^4.1.0"
  }
}
